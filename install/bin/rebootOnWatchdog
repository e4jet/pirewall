# This should be run by cron every  minute.  If journalctl doesn't
# find any errors, it returns 1.  If journalctl is successful (0),
# we've found an issue, so we log it and reboot.

journalctl -b -g 'NETDEV WATCHDOG' -p err --since "1 min ago" --no-pager
if [ $? != 1 ] ; then
	logger "Network watchdog, rebooting..."
	init 6
fi

# Timing issues can cause sshd to not start.  This just makes sure.

systemctl status sshd.service > /dev/null
if [ $? != 0 ] ; then
	logger "Starting sshd..."
	systemctl start sshd
fi