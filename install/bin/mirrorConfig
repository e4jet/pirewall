my $realUser   = $ARGV[0];
if (not defined $realUser) {
  die "A user name is required.\n";
}

open(FILES, "cd /home/" . $realUser . "/fw;find . |");
while(<FILES>) {
	chomp;
	$line = $_;
	if ($_ =~ /\.(\/.*)/) {
		$file = $1;
		if (-f $file && ! -d $file) {
			print "cp " . $file . " " . "/home/" . $realUser . "/fw" . $file . " ";
			$returnCode = system("cp " . $file . " " . "/home/" . $realUser . "/fw" . $file);
    			if ( $returnCode != 0 ) {
			        print " ...Failed!\n";
    			}else{
				    print " ...Success.\n";
			}
		}
	}
}

print "chmod -R 700 /home/" . $realUser . "/fw";
$returnCode = system("chmod -R 700 " . "/home/" . $realUser . "/fw");
if ( $returnCode != 0 ) {
	print " ...Failed!\n";
}else{
	print " ...Success.\n";
}

print "chown -R " . $realUser . " /home/" . $realUser . "/fw";
$returnCode = system("chown -R " . $realUser . " /home/" . $realUser . "/fw");
if ( $returnCode != 0 ) {
	print " ...Failed!\n";
}else{
	print " ...Success.\n";
}